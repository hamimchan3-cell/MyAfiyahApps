# Copy this file to .env and fill in any values you need for your project.
# For local development, Vite will load environment variables prefixed with VITE_

# NOTE: The app now uses Leaflet + OpenStreetMap tiles for mapping, so no API key is required.
# If you add other services that need keys, add them here.

# Supabase (required for auth + user progress + emergency contacts)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: enable the Google OAuth button after configuring the Google provider in Supabase
VITE_ENABLE_GOOGLE_AUTH=false
